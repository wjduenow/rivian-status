// Copy this file to include/secrets.h (gitignored) and fill in your values.
//
//   cp include/secrets.h.example include/secrets.h
//
// Phase 1 ONLY hard-codes the Rivian password here for the headless smoke-test.
// The shipped firmware NEVER persists the password (plan §1) — it is entered once
// via the web page and only session tokens are stored. Do not commit secrets.h.
#pragma once

// --- WiFi ---
#define WIFI_SSID   "your-ssid"
#define WIFI_PASS   "your-wifi-password"

// --- Rivian account ---
#define RIVIAN_EMAIL     "you@example.com"
#define RIVIAN_PASSWORD  "your-rivian-password"

// --- OTA (optional) — password for wireless firmware updates (ArduinoOTA). Must match the
// OTA_PASSWORD env var used at upload time:  OTA_PASSWORD=<pw> pio run -e phase3-ota -t upload
#define OTA_PASSWORD     "change-me-ota-pw"
